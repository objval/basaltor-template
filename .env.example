# App
# Replace the LAN IP/hostname when testing from another device.
APP_URL=http://127.0.0.1:3010
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-value

# Database
DATABASE_URL=postgres://basaltor:basaltor@127.0.0.1:5432/basaltor

# Mail (Mailpit local dev)
# SMTP_FROM is optional; when omitted, it defaults to the configured site name.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_IGNORE_TLS=true
SMTP_FROM="Storefront <noreply@your-store.local>"
MAILPIT_UI_URL=http://127.0.0.1:8025

# Optional OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
